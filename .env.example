# Copy this to .env and fill in your values

# Google OAuth credentials
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# The public URL of this server (used for the OAuth callback)
# For local use: http://localhost:3000
# For remote:    https://your-domain.com
BASE_URL=http://localhost:3000

# Random secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# Super admin email — this user can never be removed from the admin list via UI
SUPER_ADMIN_EMAIL=your-email@gmail.com

# Explicit path to the claude CLI (default: "claude", assumes it's on PATH)
# Useful on Windows or if claude is not on the system PATH in a PTY context
# Linux/Mac example:   CLAUDE_PATH=/usr/local/bin/claude
# Windows example:     CLAUDE_PATH=C:\Users\you\AppData\Roaming\npm\claude.cmd
# CLAUDE_PATH=

# Port to listen on (default: 3000)
# PORT=3000
