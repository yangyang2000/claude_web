# Copy this to .env and fill in your values

# Google OAuth credentials
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# The public URL of this server (used for the OAuth callback)
# For local use: http://localhost:3000
# For remote:    https://your-domain.com
BASE_URL=http://localhost:3000

# Random secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# Port to listen on (default: 3000)
# PORT=3000
